# Local development (or set these manually on Railway if not using their MySQL plugin)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=smarthire_db
DB_PORT=3306

# Flask
SECRET_KEY=change_this_to_a_random_secret_string
FLASK_DEBUG=False

# Note: If you add Railway's MySQL plugin, it auto-injects MYSQLHOST,
# MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE, MYSQLPORT — config.py already
# falls back to those automatically, so you don't need to set DB_* again.
